# Server
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Database
MONGO_URI=mongodb://127.0.0.1:27017/hrms

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d
COOKIE_NAME=hrms_token

# Outbound email (SMTP) is stored per-company in the database and managed
# under Company Settings in the admin UI. Optional vars below are ONLY used
# to pre-fill company.mail when running db:seed / db:setup — the runtime
# email service does not read them.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=Mirus Med Sciences <hr@mirus.com>

# Fresh setup defaults (npm run db:setup) / admin seed
SEED_COMPANY_SLUG=mirus
SEED_COMPANY_NAME=Mirus Med Sciences
SEED_ADMIN_EMAIL=admin@mirus.com
SEED_ADMIN_PASSWORD=ChangeMe!123
SEED_ADMIN_FIRST_NAME=Admin
SEED_ADMIN_LAST_NAME=System
